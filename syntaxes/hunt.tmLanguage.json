{
  "name": "Hunt",
  "scopeName": "source.hunt",
  "fileTypes": ["hunt"],
  "patterns": [
    { "include": "#comment" },
    { "include": "#metadata" },
    { "include": "#step" }
  ],
  "repository": {
    "comment": {
      "name": "comment.line.number-sign.hunt",
      "match": "^\\s*#.*$"
    },
    "metadata": {
      "patterns": [
        {
          "name": "meta.annotation.hunt",
          "match": "^(@context|@title|@blueprint|@tags|@data|@schedule)(:)(.*)$",
          "captures": {
            "1": { "name": "keyword.other.metadata.hunt" },
            "2": { "name": "punctuation.separator.hunt" },
            "3": { "name": "string.unquoted.metadata.value.hunt" }
          }
        },
        {
          "name": "meta.variable-declaration.hunt",
          "match": "^(@var)(:)\\s*(\\{?\\w+\\}?)\\s*(=)\\s*(.*)",
          "captures": {
            "1": { "name": "keyword.other.metadata.hunt" },
            "2": { "name": "punctuation.separator.hunt" },
            "3": { "name": "variable.other.hunt" },
            "4": { "name": "keyword.operator.assignment.hunt" },
            "5": { "name": "string.unquoted.metadata.value.hunt" }
          }
        },
        {
          "name": "meta.script-alias.hunt",
          "match": "^(@script)(:)\\s*(\\{?\\w+\\}?)\\s*(=)\\s*(.*)",
          "captures": {
            "1": { "name": "keyword.other.metadata.hunt" },
            "2": { "name": "punctuation.separator.hunt" },
            "3": { "name": "variable.other.hunt" },
            "4": { "name": "keyword.operator.assignment.hunt" },
            "5": { "name": "string.unquoted.metadata.value.hunt" }
          }
        },
        {
          "name": "meta.hook-marker.hunt",
          "match": "^\\s*(\\[(?:END\\s+)?(?:SETUP|TEARDOWN)\\])\\s*$",
          "captures": {
            "1": { "name": "keyword.control.hook.hunt" }
          }
        }
      ]
    },
    "step": {
      "patterns": [
        {
          "name": "meta.step-header.hunt",
          "match": "^\\s*(?:\\d+\\.\\s*)?\\b(STEP)\\s*(\\d*)\\s*(:)\\s*(.*)",
          "captures": {
            "1": { "name": "keyword.control.step.hunt" },
            "2": { "name": "constant.numeric.step-number.hunt" },
            "3": { "name": "punctuation.separator.hunt" },
            "4": { "name": "entity.name.section.hunt" }
          }
        },
        {
          "name": "meta.step.hunt",
          "begin": "^\\s*(\\d+\\.)",
          "beginCaptures": {
            "1": { "name": "constant.numeric.step-number.hunt" }
          },
          "end": "$",
          "patterns": [
            { "include": "#set-command" },
            { "include": "#system-keyword" },
            { "include": "#action-verb" },
            { "include": "#quoted-single" },
            { "include": "#quoted-double" },
            { "include": "#variable" },
            { "include": "#url" },
            { "include": "#modifier" }
          ]
        },
        {
          "name": "meta.freeform.hunt",
          "begin": "^\\s*(?!#|@|\\d+\\.)",
          "end": "$",
          "patterns": [
            { "include": "#set-command" },
            { "include": "#system-keyword" },
            { "include": "#action-verb" },
            { "include": "#quoted-single" },
            { "include": "#quoted-double" },
            { "include": "#variable" },
            { "include": "#url" },
            { "include": "#modifier" }
          ]
        }
      ]
    },
    "set-command": {
      "name": "meta.set-command.hunt",
      "match": "(?i)\\b(SET)\\s+(\\{?\\w+\\}?)\\s*(=)\\s*(.*)",
      "captures": {
        "1": { "name": "keyword.control.hunt" },
        "2": { "name": "variable.other.hunt" },
        "3": { "name": "keyword.operator.assignment.hunt" },
        "4": { "name": "string.unquoted.value.hunt" }
      }
    },
    "system-keyword": {
      "name": "keyword.control.hunt",
      "match": "(?i)\\b(NAVIGATE to|NAVIGATE|OPEN\\s+APP|VERIFY VISUAL|VERIFY SOFTLY|VERIFY that|VERIFY|EXTRACT|SCROLL DOWN|SCROLL|PRESS ENTER|PRESS|RIGHT CLICK|UPLOAD|MOCK\\s+(?:GET|POST|PUT|PATCH|DELETE)|WAIT FOR RESPONSE|WAIT FOR|WAIT|DONE|DOUBLE CLICK|HOVER|CALL PYTHON|SCAN PAGE|SET|PRINT|DEBUG VARS|DEBUG|PAUSE|IF|ELIF|ELSE)\\b"
    },
    "action-verb": {
      "name": "keyword.operator.action.hunt",
      "match": "(?i)\\b(Click|Fill|Type|Select|Choose|Check|Uncheck|Hover|Drag|Drop|Locate|Navigate|Enter|Upload)\\b"
    },
    "quoted-single": {
      "name": "string.quoted.single.hunt",
      "begin": "'",
      "end": "'",
      "patterns": [
        { "include": "#variable" }
      ]
    },
    "quoted-double": {
      "name": "string.quoted.double.hunt",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "include": "#variable" }
      ]
    },
    "variable": {
      "name": "variable.other.hunt",
      "match": "\\{[a-zA-Z_][a-zA-Z0-9_]*\\}"
    },
    "url": {
      "name": "markup.underline.link.hunt",
      "match": "https?://[^\\s]+"
    },
    "modifier": {
      "name": "keyword.other.modifier.hunt",
      "match": "(?i)\\b(if exists|optional|NOT|DISABLED|ENABLED|SOFTLY|VISUAL|ON HEADER|ON FOOTER|is present|is checked|is NOT checked|is NOT present|be visible|be hidden|disappear|into|from|to|that|the|with|near|inside|on|header|footer|row|field|button|link|checkbox|dropdown|input|has|text|placeholder|value|args|exists|contains)\\b"
    }
  }
}
